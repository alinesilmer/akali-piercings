rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null
          && request.auth.uid == "STSA4lH7m0frbYCv323NxT4RtA62";
    }

    // ─── Users ────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read, write: if isAdmin();
    }

    // ─── Services ─────────────────────────────────────────────────────────────

    match /services/{serviceId} {
      allow get:    if isAdmin() || resource.data.isActive == true;
      allow list:   if isAdmin() || resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Categories ───────────────────────────────────────────────────────────

    match /categories/{categoryId} {
      allow get:    if isAdmin() || resource.data.isActive == true;
      allow list:   if isAdmin() || resource.data.isActive == true;
      allow create, update, delete: if isAdmin();
    }

    // ─── Products ─────────────────────────────────────────────────────────────

    match /products/{productId} {
      allow get:    if isAdmin() || resource.data.status == "published";
      allow list:   if isAdmin() || resource.data.status == "published";
      allow create, update, delete: if isAdmin();
    }
  }
}
